datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  id           Int       @id @default(autoincrement())
  title        String
  deadline     DateTime?
  importance   Int
  is_completed Boolean   @default(false)
  categoryId   Int
  category     Category  @relation(fields: [categoryId], references: [id])
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  tasks Task[]
}